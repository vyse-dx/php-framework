{
    "name": "vyse/framework",
    "description": "Framework helpers for Vyse projects, eg Doctrine and Symfony.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Vyse\\Framework\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "authors": [
        {
            "name": "Andy Fletcher"
        }
    ],
    "require": {
        "dama/doctrine-test-bundle": "^8.6",
        "doctrine/orm": "^3.6",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "php": "^8.5",
        "phpstan/phpstan-doctrine": "^2.0",
        "symfony/browser-kit": "^8.0",
        "symfony/console": "7.4.*",
        "symfony/css-selector": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/flex": "^2.4",
        "symfony/framework-bundle": "^7.4",
        "symfony/monolog-bundle": "^4.0",
        "symfony/phpunit-bridge": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/yaml": "^8.0",
        "vyse/toolchain": "^1.0",
        "symfony/ux-twig-component": "^3.0",
        "symfonycasts/tailwind-bundle": "^0.12.0",
        "gehrisandro/tailwind-merge-php": "^1.2",
        "tales-from-a-dev/twig-tailwind-extra": "^1.1",
        "symfony/ux-toolkit": "^3.0",
        "twig/extra-bundle": "^3.24",
        "twig/html-extra": "^3.24"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true,
            "vyse/installer": true
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        }
    },
    "extra": {
        "vyse": {
            "bin": [
                "vyse-bin"
            ],
            "hooks": {
                "pre-push": {
                    "101-data-test": "vyse/test/data",
                    "102-web-test": "vyse/test/web"
                }
            }
        }
    }
}
