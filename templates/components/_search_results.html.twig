{% if results is empty %}
    <li class="relative cursor-default select-none py-2 px-4 text-sm text-gray-500 italic">
        No users found.
    </li>
{% else %}
    {% for user in results %}
        <li class="relative cursor-default select-none py-2 px-4 text-sm text-gray-900 hover:bg-blue-50 transition-colors">
            <div class="flex items-center">
                <span class="font-medium block truncate">{{ user.name }}</span>
                <span class="ml-2 text-gray-500 text-xs">{{ user.email }}</span>
            </div>
        </li>
    {% endfor %}
{% endif %}