{% extends 'base.html.twig' %}

{% block title %}Database Integration Test{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
    .stats-card { 
        background: #e3f2fd; 
        border-left: 5px solid #2196f3; 
        padding: 1.5em; 
        margin: 1em 0; 
        border-radius: 4px;
    }
    .badge {
        background: #2196f3;
        color: white;
        padding: 0.2em 0.6em;
        border-radius: 10px;
        font-size: 0.9em;
    }
</style>

<div class="example-wrapper">
    <h1>Hello {{ controller_name }}! ✅</h1>

    <div class="stats-card">
        <h3>📊 Database Stats</h3>
        <p>Total <code>Foo</code> records in database: <strong>{{ total_foos }}</strong></p>
        <p>Latest record created with ID: <span class="badge">#{{ latest_id }}</span></p>
    </div>

    <p>Your full stack is now operational:</p>
    <ul>
        <li><strong>Controller:</strong> <code>TestController.php</code></li>
        <li><strong>Domain Repo:</strong> <code>FooRepository.php</code></li>
        <li><strong>Infrastructure Repo:</strong> <code>FooEntityRepository.php</code></li>
        <li><strong>Database:</strong> PostgreSQL (Docker)</li>
    </ul>

    <p><small>Refresh the page to trigger a new <code>persist()</code> and <code>flush()</code>.</small></p>

    <Submit class="bg-red-500">
        <svg class="w-4 h-4 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Save Changes
    </Submit>
</div>
{% endblock %}
